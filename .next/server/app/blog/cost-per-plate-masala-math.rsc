5:["$","main",null,{"children":["$","article",null,{"className":"pt-32 md:pt-40 pb-24 px-6 md:px-10 max-w-3xl mx-auto","children":[["$","p",null,{"className":"rs-eyebrow","style":{"fontSize":"0.7rem","color":"#D22C2E"},"children":["Kitchen economics · ","2026-06-28"," · ",4," min read"]}],["$","h1",null,{"className":"rs-display mt-4","style":{"fontSize":"clamp(2rem, 4.5vw, 3rem)","lineHeight":1.1,"fontWeight":600,"color":"#2A160C"},"children":"Cost-per-plate: the only masala metric that matters"}],["$","div",null,{"className":"mt-8 grid gap-5","children":[["$","p","0",{"className":"rs-body","style":{"color":"#4A3728","fontSize":"1.02rem","lineHeight":1.85},"children":"Purchase teams compare masalas by price per kilo. Kitchens experience them as cost per plate. The gap between those two numbers is where menus lose money."}],["$","p","1",{"className":"rs-body","style":{"color":"#4A3728","fontSize":"1.02rem","lineHeight":1.85},"children":"The math is simple: cost per plate = price per kilo ÷ plates per kilo. A ₹620/kg garam masala that seasons 160 plates costs ₹3.88 a plate. A ₹450/kg blend that manages only 90 plates — because it is cut with filler and needs double dosing — costs ₹5 a plate. The 'cheaper' blend is 29% more expensive where it counts."}],["$","p","2",{"className":"rs-body","style":{"color":"#4A3728","fontSize":"1.02rem","lineHeight":1.85},"children":"Yield per kilo is driven by three things: concentration (no fillers means lower dosage), consistency (no re-seasoning failed batches), and freshness retention (a blend that fades in the tin forces heavier hands by month two)."}],["$","p","3",{"className":"rs-body","style":{"color":"#4A3728","fontSize":"1.02rem","lineHeight":1.85},"children":"So when you evaluate a supplier, ask for the yield claim in writing — plates per kilo for a defined recipe — and then verify it in your own kitchen for a fortnight. Any serious professional-kitchen supplier will welcome the test; it is the test the honest ones win."}],["$","p","4",{"className":"rs-body","style":{"color":"#4A3728","fontSize":"1.02rem","lineHeight":1.85},"children":"We publish indicative yields on every product page and let you run your own numbers in the calculator. Bring your recipes; the arithmetic is the pitch."}]]}],["$","div",null,{"className":"mt-12 rounded-2xl p-7","style":{"background":"rgba(250,162,25,0.12)","border":"1px solid rgba(250,162,25,0.4)"},"children":[["$","p",null,{"className":"rs-display","style":{"fontSize":"1.2rem","color":"#2A160C","fontWeight":600},"children":"Run the numbers on your own menu."}],["$","p",null,{"className":"rs-body mt-2","style":{"color":"#6B5040","fontSize":"0.92rem"},"children":"The cost-per-plate calculator on our products page uses the same math as this article."}],["$","$L10",null,{"href":"/products","className":"rs-btn inline-block mt-5 px-6 py-3 rounded-full","style":{"background":"#D22C2E","color":"#fff","fontSize":"0.75rem"},"children":"Open the calculator"}]]}],["$","$L10",null,{"href":"/blog","className":"rs-body inline-block mt-8 underline","style":{"color":"#D22C2E","fontSize":"0.9rem"},"children":"← All articles"}]]}]}]
